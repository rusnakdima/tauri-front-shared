{
  "name": "@tauri-front/shared",
  "version": "0.1.0",
  "packageManager": "bun@>=1.0",
  "private": true,
  "workspaces": [
    "projects/*"
  ],
  "scripts": {
    "build": "npm run build:shared",
    "build:shared": "cd projects/shared && npm run build",
    "dev": "npm run build && npm run build:watch",
    "build:watch": "npm run build:watch --workspaces",
    "generate-component-manifest": "bun run scripts/generate-component-manifest.ts"
  },
  "devDependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/common": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/material": "^22.0.0",
    "@angular/router": "22.0.6",
    "@tauri-apps/api": "^2.11.1",
    "lit": "^3.0.0",
    "ng-packagr": "^22.0.0",
    "rxjs": "^7.8.2",
    "sass": "^1.101.0",
    "typescript": "6"
  },
  "dependencies": {
    "@angular/animations": "^20.3.26",
    "@angular/compiler": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@angular/elements": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/platform-browser-dynamic": "22.0.6",
    "tslib": "^2.8.1"
  }
}
