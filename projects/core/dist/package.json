{
  "name": "@tauri-front/core",
  "version": "0.1.0",
  "description": "Core Angular services for Tauri apps (SignalStore, Crud, Theme, SchemaRenderer, etc.)",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "main": "fesm2022/tauri-front-core.mjs",
  "module": "fesm2022/tauri-front-core.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./fesm2022/tauri-front-core.mjs",
      "types": "./index.d.ts",
      "default": "./fesm2022/tauri-front-core.mjs"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@tauri-apps/api": ">=2.0.0",
    "@tauri-front/storage": "*"
  },
  "typings": "index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "tslib": "^2.3.0"
  }
}