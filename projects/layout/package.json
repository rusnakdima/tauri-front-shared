{
  "name": "@tauri-front/layout",
  "version": "0.1.0",
  "description": "Shared layout Lit Web Components (Header, Sidebar, Footer, SplitView, etc.) for Tauri apps",
  "type": "module",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
