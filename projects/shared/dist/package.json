{
  "name": "@tauri-front/shared",
  "version": "0.1.1-1782666230370",
  "description": "Unified shared library for Tauri apps with style variants",
  "type": "module",
  "main": "./fesm2022/tauri-front-shared.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./fesm2022/tauri-front-shared.mjs",
      "types": "./types/tauri-front-shared.d.ts",
      "default": "./fesm2022/tauri-front-shared.mjs"
    },
    "./styles": {
      "default": "./styles/ui-system.css"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/platform-browser": ">=17.0.0",
    "@tauri-apps/api": ">=2.0.0",
    "rxjs": ">=7.0.0",
    "@angular/animations": ">=17.0.0",
    "@angular/material": ">=17.0.0"
  },
  "module": "fesm2022/tauri-front-shared.mjs",
  "typings": "types/tauri-front-shared.d.ts",
  "sideEffects": false,
  "dependencies": {
    "tslib": "^2.3.0"
  }
}