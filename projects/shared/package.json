{
  "name": "@tauri-front/shared",
  "version": "0.1.1-1782666230370",
  "description": "Unified shared library for Tauri apps with style variants",
  "type": "module",
  "main": "./fesm2022/tauri-front-shared.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./fesm2022/tauri-front-shared.mjs",
