  "scripts": {
    "lint:styles": "stylelint \"src/styles/**/*.scss\"",
    "build:scss": "sass --no-source-map --style=compressed src/styles/library-utilities.scss dist/styles/library-utilities.css && sass --no-source-map --style=compressed src/styles/ui-system.scss dist/styles/ui-system.css",
    "build": "npm run build:scss && ng-packagr -p ng-package.json && node ../../scripts/fix-package-json.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/platform-browser": ">=17.0.0",
    "@tauri-apps/api": ">=2.0.0",
    "rxjs": ">=7.0.0",
    "@angular/animations": ">=17.0.0",
    "@angular/material": ">=17.0.0"
  },
  "devDependencies": {
    "@angular/cdk": "^22.0.0",
