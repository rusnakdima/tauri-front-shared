    },
    "./styles/themes/glassmorphism/components.css": {
      "default": "./styles/themes/glassmorphism/components.css"
    },
    "./styles/themes/neumorphism/tokens": {
      "default": "./styles/themes/neumorphism/tokens.css"
    },
    "./styles/themes/neumorphism/tokens.css": {
      "default": "./styles/themes/neumorphism/tokens.css"
    },
    "./styles/themes/neumorphism/components": {
      "default": "./styles/themes/neumorphism/components.css"
    },
    "./styles/themes/neumorphism/components.css": {
      "default": "./styles/themes/neumorphism/components.css"
    },
    "./styles/themes/claymorphism/tokens": {
      "default": "./styles/themes/claymorphism/tokens.css"
    },
    "./styles/themes/claymorphism/tokens.css": {
