    "./styles/themes/brutalism/tokens": {
      "default": "./styles/themes/brutalism/tokens.css"
    },
    "./styles/themes/brutalism/tokens.css": {
      "default": "./styles/themes/brutalism/tokens.css"
    },
    "./styles/themes/brutalism/components": {
      "default": "./styles/themes/brutalism/components.css"
    },
    "./styles/themes/brutalism/components.css": {
