    "@tauri-apps/api": "^2.11.1",
    "jsdom": "^24.0.0",
    "ng-packagr": "^22.0.0",
    "sass": "^1.77.0",
    "typescript": "~6.0.0",
    "vitest": "^1.0.0",
    "stylelint": "^16.0.0"
  }
}
