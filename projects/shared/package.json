    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/platform-browser": ">=17.0.0",
    "@tauri-apps/api": ">=2.0.0",
    "rxjs": ">=7.0.0",
    "@angular/material": ">=17.0.0"
  },
  "devDependencies": {
    "@angular/cdk": "^20.0.0",
    "@angular/material": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@tauri-apps/api": "^2.11.1",
    "jsdom": "^24.0.0",
    "ng-packagr": "^20.3.2",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0"
  }
}
