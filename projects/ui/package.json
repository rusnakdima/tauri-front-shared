{
  "name": "@tauri-front/ui",
  "version": "0.1.0",
  "description": "Shared UI components for Tauri apps (Button, Input, Checkbox, Tabs, etc.)",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.lit.json",
    "build:watch": "tsc --project tsconfig.lit.json --watch --preserveWatchOutput"
  }
}
