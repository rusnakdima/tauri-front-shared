{
  "name": "@tauri-front/ui",
  "version": "0.1.0",
  "description": "Shared UI components for Tauri apps (Button, Input, Checkbox, Tabs, etc.)",
  "type": "module",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && npm run build:lit",
    "build:lit": "tsc --project tsconfig.lit.json",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
